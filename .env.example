# MT5 EA bridge URLs (comma-separated, priority order)
BRIDGE_URLS=http://host.docker.internal:5005,http://host.docker.internal:5006,http://host.docker.internal:5007,http://host.docker.internal:5003

# TwelveData API keys for history backfill (optional, comma-separated)
TWELVEDATA_KEYS=key1,key2,key3,key4

# Cache config
MAX_CANDLES=50000
POLL_INTERVAL=10
CANDLES_PER_POLL=500
BOOTSTRAP_THRESHOLD=10000
